PORT=5000
FRONTEND_URL=http://localhost:8080

# MongoDB
MONGO_URI=mongodb://localhost:27017/vulnixai

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Gemini API Keys (comma-separated for fallback) - Main model for repo scanning
# Get your API keys from https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=your_gemini_key1,your_gemini_key2,your_gemini_key3
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Groq API Keys (comma-separated for fallback) - Fallback model
# Get your API keys from https://console.groq.com/
GROQ_API_KEYS=your_groq_key1,your_groq_key2,your_groq_key3
GROQ_API_URL=https://api.groq.com/openai/v1

# Legacy single key support (optional, will be overridden by GEMINI_API_KEYS/GROQ_API_KEYS)
GROQ_API_KEY=your_groq_api_key

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Environment
NODE_ENV=development
